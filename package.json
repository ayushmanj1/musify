{
  "name": "musify",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"node api/index.js\" \"cd frontend && npm run dev\"",
    "build": "cd frontend && npm install --legacy-peer-deps && npm run build",
    "vercel-build": "cd frontend && npm install --legacy-peer-deps && npm run build",
    "start": "node --max-old-space-size=256 api/index.js"
  },
  "dependencies": {
    "@distube/ytdl-core": "^4.16.12",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "lru-cache": "^11.0.0",
    "play-dl": "^1.9.7",
    "youtube-dl-exec": "^3.1.5",
    "youtube-sr": "^4.3.11",
    "youtubei.js": "^17.0.1",
    "ytdl-core-enhanced": "^2.3.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
